/*
 * TERRA-QUANT Nextflow Pipeline Configuration
 * Quantifies TERRA (Telomeric Repeat-containing RNA) from bulk RNA-seq
 */

params {
    // ---- Input ----
    reads           = null       // Path to FASTQ files, e.g. '/path/to/reads/*_R{1,2}.fastq.gz'
    single_end      = false      // Set to true for single-end reads

    // ---- Reference ----
    star_index      = null       // Path to pre-built STAR genome index directory
    genome_fasta    = null       // CHM13 T2T FASTA (required if star_index not provided)
    gtf             = "${projectDir}/../CHM13_v2.0_add_TERRA_ITS_AS_v5.gtf.gz"
    telo_ref        = "${projectDir}/assets/s.teloseq_v2.fa"

    // ---- Options ----
    trim_quality    = 30
    strandedness    = 'reverse'  // HTSeq strandedness: 'reverse', 'yes', or 'no'
    run_bbduk       = false      // Run BBDuk telomeric content estimation
    run_bamcoverage = false      // Generate bigwig coverage tracks

    // ---- YARN normalization (optional) ----
    run_yarn        = false
    annotation      = null       // Sample annotation CSV/XLSX (required if run_yarn = true)
    yarn_target     = null       // Column name in annotation for normalization grouping

    // ---- Resources ----
    max_cpus        = 8
    max_memory      = '64.GB'

    // ---- Output ----
    outdir          = './results'
}

process {
    cpus   = { Math.min(4, params.max_cpus) }
    memory = { '8.GB' }

    withName: 'STAR_INDEX' {
        cpus   = { params.max_cpus }
        memory = { params.max_memory }
    }
    withName: 'STAR_ALIGN' {
        cpus   = { params.max_cpus }
        memory = { '48.GB' }
    }
    withName: 'HTSEQ_COUNT' {
        cpus   = { Math.min(4, params.max_cpus) }
        memory = { '16.GB' }
    }
}

profiles {
    standard {
        process.executor = 'local'
    }
    slurm {
        process.executor = 'slurm'
        process.queue    = 'batch'
    }
    docker {
        docker.enabled = true
        process {
            withName: 'TRIM_GALORE'   { container = 'quay.io/biocontainers/trim-galore:0.6.10--hdfd78af_0' }
            withName: 'STAR_INDEX'    { container = 'quay.io/biocontainers/star:2.7.11b--h43eeafb_0' }
            withName: 'STAR_ALIGN'    { container = 'quay.io/biocontainers/mulled-v2-1fa26d1ce03c295fe2fdcb85b62a63ae47571f8b:a]0e22c16c6428ead72ef2c4af9828f4f2ec0e8a1-0' }
            withName: 'HTSEQ_COUNT'   { container = 'quay.io/biocontainers/htseq:2.0.5--py310h5aa3a86_0' }
            withName: 'BAMCOVERAGE'   { container = 'quay.io/biocontainers/deeptools:3.5.5--pyhdfd78af_0' }
            withName: 'BBDUK_TELO'    { container = 'quay.io/biocontainers/bbmap:39.06--h92535d8_0' }
            withName: 'SUMMARIZE_COUNTS' { container = 'rocker/tidyverse:4.3' }
            withName: 'YARN_NORMALIZE'   { container = 'bioconductor/bioconductor_docker:RELEASE_3_18' }
        }
    }
    singularity {
        singularity.enabled = true
        singularity.autoMounts = true
        process {
            withName: 'TRIM_GALORE'   { container = 'https://depot.galaxyproject.org/singularity/trim-galore:0.6.10--hdfd78af_0' }
            withName: 'STAR_INDEX'    { container = 'https://depot.galaxyproject.org/singularity/star:2.7.11b--h43eeafb_0' }
            withName: 'STAR_ALIGN'    { container = 'https://depot.galaxyproject.org/singularity/star:2.7.11b--h43eeafb_0' }
            withName: 'HTSEQ_COUNT'   { container = 'https://depot.galaxyproject.org/singularity/htseq:2.0.5--py310h5aa3a86_0' }
            withName: 'BAMCOVERAGE'   { container = 'https://depot.galaxyproject.org/singularity/deeptools:3.5.5--pyhdfd78af_0' }
            withName: 'BBDUK_TELO'    { container = 'https://depot.galaxyproject.org/singularity/bbmap:39.06--h92535d8_0' }
        }
    }
    conda {
        conda.enabled = true
        process {
            withName: 'TRIM_GALORE'  { conda = 'bioconda::trim-galore=0.6.10' }
            withName: 'STAR_INDEX'   { conda = 'bioconda::star=2.7.11b' }
            withName: 'STAR_ALIGN'   { conda = 'bioconda::star=2.7.11b bioconda::samtools=1.19' }
            withName: 'HTSEQ_COUNT'  { conda = 'bioconda::htseq=2.0.5' }
            withName: 'BAMCOVERAGE'  { conda = 'bioconda::deeptools=3.5.5' }
            withName: 'BBDUK_TELO'   { conda = 'bioconda::bbmap=39.06' }
        }
    }
}

timeline {
    enabled = true
    file    = "${params.outdir}/pipeline_info/timeline.html"
}
report {
    enabled = true
    file    = "${params.outdir}/pipeline_info/report.html"
}
